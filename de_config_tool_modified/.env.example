# ════════════════════════════════════════════════════════════════
#  DE Config Tool — Environment Variables
#  Copy this to .env and fill in your values
# ════════════════════════════════════════════════════════════════

# ── LLM Inference (Anthropic Claude) ─────────────────────────────
# Required for AI-powered config inference (/api/extract/infer)
# Without this, the tool uses pattern matching as fallback
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── AWS Credentials (optional — only needed for real extraction) ──
# Leave blank to use IAM role, instance profile, or ~/.aws/credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# ── Azure Credentials (optional) ─────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# ── Databricks (optional) ─────────────────────────────────────────
DATABRICKS_HOST=https://adb-xxx.azuredatabricks.net
DATABRICKS_TOKEN=dapi...

# ── Snowflake (optional) ──────────────────────────────────────────
SNOWFLAKE_ACCOUNT=myorg-myaccount
SNOWFLAKE_USER=ETL_SERVICE_USER
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=PROD_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=SYSADMIN

# ── App Settings ──────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
