# --- DataHub Configuration ---
# DataHub GMS endpoint (default for local quickstart)
DATAHUB_GMS_URL=http://localhost:8080
# Optional: DataHub token (if auth enabled)
DATAHUB_TOKEN=

# --- LLM Layer Configuration ---
# Enable/Disable the Agentic Pipeline Discovery layer (LLM)
LLM_ENABLED=true
# LLM model to use (Ollama: deepseek-r1:1.5b, Anthropic: claude-3-5-sonnet-20240620)
LLM_MODEL=deepseek-r1:1.5b

# Ollama Base URL (if using local Ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic API Key (if using Claude)
ANTHROPIC_API_KEY=

# --- Cloud Provider Credentials (AWS) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# --- Cloud Provider Credentials (Azure) ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# --- Cloud Provider Credentials (GCP) ---
GCP_PROJECT_ID=
GCP_MOCK_ENABLED=false

# --- Specialized Tools ---
DATABRICKS_HOST=
DATABRICKS_TOKEN=

SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
